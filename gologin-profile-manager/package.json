{
  "name": "gologin-profile-manager",
  "version": "1.0.0",
  "description": "GoLogin Profile Manager with Electron UI",
  "main": "src/frontend/main.js",
  "scripts": {
    "start:api": "node src/backend/server.js",
    "start:electron": "electron .",
    "start": "concurrently \"npm run start:api\" \"npm run start:electron\"",
    "dev": "concurrently \"npm run start:api\" \"npm run start:electron\"",
    "build": "electron-builder --win",
    "build:portable": "electron-builder --win portable",
    "build:dir": "electron-builder --win --dir",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "ZTeam",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.1.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "extract-zip": "^2.0.1",
    "gologin": "^2.2.8",
    "mongodb": "^5.0.1",
    "playwright": "^1.58.2",
    "puppeteer-core": "^24.37.2",
    "request": "^2.88.2",
    "requestretry": "^7.1.0",
    "socks": "^2.8.7",
    "socks-proxy-agent": "^8.0.5",
    "sqlite": "^4.1.2",
    "sqlite3": "^5.1.2",
    "winston": "^3.8.2",
    "zip-lib": "^0.7.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^33.4.11",
    "electron-builder": "^24.13.3",
    "jimp": "^1.6.0",
    "png-to-ico": "^3.0.1"
  },
  "build": {
    "appId": "com.zteam.gologin-profile-manager",
    "productName": "GoLogin Profile Manager",
    "copyright": "Copyright © 2024 ZTeam",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "**/*",
      "!profiles/**/*",
      "!dist/**/*",
      "!build/**/*",
      "!*.log",
      "!*.md",
      "!.git/**/*",
      "!.env*"
    ],
    "extraResources": [
      {
        "from": "orbita-browser",
        "to": "orbita-browser",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "assets",
        "to": "../assets",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": ".env",
        "to": "../.env"
      },
      {
        "from": "settings.json",
        "to": "../settings.json"
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "portable": {
      "artifactName": "${productName}-${version}-Portable.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "GoLogin Profile Manager"
    },
    "asar": false
  }
}
